# ============================================
# SafePlate - Local Development (.env.local)
# ============================================
# Copy this file to .env.local and fill in your actual keys
# This file is gitignored and used for local development
# ============================================

# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB - Replace with your MongoDB connection string
MONGO_URI=mongodb://localhost:27017/safeplate_dev

# Clerk Authentication — from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY
CLERK_SECRET_KEY=sk_test_YOUR_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Stripe - Replace with your Stripe test keys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Redis - Local Redis instance
REDIS_URL=redis://localhost:6379

# Twilio - Optional, leave empty if not using
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend - Optional, leave empty if not using
RESEND_API_KEY=
RESEND_FROM_EMAIL=SafePlate <orders@safeplate.com>

# Google Maps API - Optional, leave empty if not using
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cron Job Authentication - Generate with: openssl rand -hex 32
CRON_API_KEY=dev-local-key-change-in-production

# Optional: debug / development helpers
# NEXT_PUBLIC_DEBUG_MODE=true
# DEBUG_MODE=true
