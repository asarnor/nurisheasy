# ============================================
# SafePlate Environment Variables Template
# ============================================
# Copy this file to .env.local for local development
# For Railway deployment, set these in the Railway dashboard
# ============================================

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# MONGODB DATABASE
# ============================================
# MongoDB Atlas connection string or Railway MongoDB plugin URL
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/safeplate?retryWrites=true&w=majority

# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from: https://dashboard.clerk.com
# Publishable Key: Dashboard > API Keys > Publishable Key
# Secret Key: Dashboard > API Keys > Secret Key
# Webhook Secret: Dashboard > Webhooks > [Your Endpoint] > Signing Secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YWJzb2x1dGUtd29sZi0zMi5jbGVyay5hY2NvdW50cy5kZXYk"
CLERK_SECRET_KEY="sk_test_BYfqzNYy0EgjOu8qLehs2TUwlWokeloL44m6vkUbWi"
CLERK_WEBHOOK_SECRET="whsec_Jy/Det4s6M1+fyKOp9gQcYkQvMl6wpw2"

# Clerk URL Configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================
# STRIPE PAYMENTS
# ============================================
# Get these from: https://dashboard.stripe.com
# Secret Key: Dashboard > Developers > API Keys > Secret Key
# Publishable Key: Dashboard > Developers > API Keys > Publishable Key
# Webhook Secret: Dashboard > Developers > Webhooks > [Your Endpoint] > Signing Secret
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# REDIS (Caching & Session Storage)
# ============================================
# Local: redis://localhost:6379
# Railway: Get from Railway Redis plugin dashboard
# Redis Cloud: Get from Redis Cloud dashboard
REDIS_URL=redis://localhost:6379

# ============================================
# TWILIO (SMS & Voice Notifications)
# ============================================
# Get these from: https://console.twilio.com
# Account SID: Dashboard > Account Info
# Auth Token: Dashboard > Account Info
# Phone Number: Dashboard > Phone Numbers > Buy a Number
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# RESEND (Email Notifications)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=SafePlate <orders@safeplate.com>

# ============================================
# GOOGLE MAPS API
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=...

# ============================================
# CRON JOB AUTHENTICATION
# ============================================
# Generate a secure random string for protecting cron endpoints
# Use: openssl rand -hex 32
CRON_API_KEY=your-secure-random-key-here

# ============================================
# OPTIONAL: CUSTOM CONFIGURATION
# ============================================
CUSTOM_KEY=optional-custom-value
